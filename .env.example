# BreakGen Environment Configuration
# Copy this file to .env and fill in your values

# Debug mode (disable in production)
BREAKGEN_DEBUG=true

# Database (default: SQLite in server directory)
# BREAKGEN_DATABASE_URL=sqlite+aiosqlite:///./breakgen.db

# Meshy AI API key (optional — stub mode used when empty)
BREAKGEN_MESHY_API_KEY=
